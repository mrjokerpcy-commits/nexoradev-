# ============================================
# NEXORA PANEL — ENVIRONMENT VARIABLES
# Rename this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# Server
PORT=3001
NODE_ENV=production

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexora_panel
DB_USER=nexora_user
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# JWT Secret — make this VERY long and random
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Owner credentials (set once at setup)
OWNER_USERNAME=owner
OWNER_PASSWORD=CHANGE_THIS_STRONG_OWNER_PASSWORD

# CORS — your frontend domain
FRONTEND_URL=https://nexoradev.com

# Upload folder
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
